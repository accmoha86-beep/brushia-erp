# ──────────────────────────────────────────────
# Brushia ERP — Environment Configuration
# Copy this to .env and fill in values
# ──────────────────────────────────────────────

# ─── Application ───
NODE_ENV=development
APP_NAME=brushia-erp
APP_PORT=3001
APP_URL=http://localhost:3001
WEB_URL=http://localhost:3000
LOG_LEVEL=debug

# ─── Database (PostgreSQL) ───
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=brushia
DATABASE_USER=brushia
DATABASE_PASSWORD=brushia_dev_2024
DATABASE_URL=postgresql://brushia:brushia_dev_2024@localhost:5432/brushia
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ─── Authentication ───
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_minimum_32_characters
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
BCRYPT_ROUNDS=12

# ─── CORS ───
CORS_ORIGINS=http://localhost:3000

# ─── Rate Limiting ───
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── File Storage (S3-compatible) ───
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ─── Queue (BullMQ) ───
QUEUE_PREFIX=brushia

# ─── Sentry ───
# SENTRY_DSN=

# ─── Email (SMTP) ───
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@brushia.net
